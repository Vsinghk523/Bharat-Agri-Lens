{
  "name": "@bal/mobile",
  "private": true,
  "version": "0.1.0",
  "description": "BharatAgriLens Android + iOS native shell (Capacitor)",
  "scripts": {
    "sync": "pnpm --filter @bal/web build && cap sync",
    "sync:android": "pnpm --filter @bal/web build && cap sync android",
    "sync:ios": "pnpm --filter @bal/web build && cap sync ios",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "run:android": "pnpm sync:android && cap run android",
    "run:ios": "pnpm sync:ios && cap run ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/camera": "^6.1.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/preferences": "^6.0.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0"
  }
}
