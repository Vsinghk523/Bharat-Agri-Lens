# --- Core ---
APP_NAME=bharat-agri-lens-api
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bharat_agri_lens

# --- Auth / Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-in-prod-use-64-byte-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CPA_FERNET_KEY=change-me-44-char-fernet-key

# --- OTP delivery ---
OTP_TTL_SECONDS=300
OTP_RATE_LIMIT_PER_HOUR=5
RESEND_API_KEY=re_xxx
OTP_EMAIL_FROM=onboarding@bharatagrilens.in

# WhatsApp Business Cloud API (Meta) — free tier
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_OTP_TEMPLATE_NAME=bal_login_otp
WHATSAPP_OTP_TEMPLATE_LANG=en

# --- Object storage (S3-compatible) ---
# Defaults below target a local MinIO container (see README).
# For production, leave S3_ENDPOINT_URL blank to use real AWS S3, or
# set it to your Cloudflare R2 endpoint.
S3_BUCKET=bharat-agri-lens-dev
S3_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PRESIGN_TTL_SECONDS=300

# --- Inference service ---
INFERENCE_BASE_URL=http://localhost:8001
INFERENCE_TIMEOUT_SECONDS=60

# --- Background moderation / thumbnail worker ---
# Set MODERATION_ENABLED=false to disable the worker in this process.
MODERATION_ENABLED=true
MODERATION_POLL_INTERVAL_SECONDS=10
MODERATION_BATCH_SIZE=5
# 10 MiB upper bound on bytes the worker will accept.
MODERATION_MAX_IMAGE_BYTES=10485760
THUMBNAIL_MAX_DIM=256
THUMBNAIL_JPEG_QUALITY=80

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
