# Normalize all text files to LF in the repo, regardless of OS.
# Working-tree line endings are still governed by core.autocrlf, but the
# bytes git stores are deterministic.
* text=auto eol=lf

# --- Source code (LF) ---
*.py        text eol=lf
*.pyi       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.sql       text eol=lf
*.mako      text eol=lf
*.dockerfile text eol=lf
Dockerfile  text eol=lf

# --- Shell / Unix tooling (LF) ---
*.sh        text eol=lf
*.bash      text eol=lf
*.env       text eol=lf
*.env.example text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
.prettierrc text eol=lf
.nvmrc      text eol=lf

# --- Windows scripts (CRLF) ---
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# --- Lockfiles: text, but suppress diffs (huge & auto-generated) ---
pnpm-lock.yaml      text eol=lf -diff
package-lock.json   text eol=lf -diff
yarn.lock           text eol=lf -diff
uv.lock             text eol=lf -diff
poetry.lock         text eol=lf -diff

# --- Images / binary assets ---
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.bmp       binary
*.ico       binary
*.webp      binary
*.pdf       binary
*.psd       binary
*.ai        binary
# SVGs are XML — treat as text
*.svg       text eol=lf

# --- Office docs (binary) ---
*.docx      binary
*.xlsx      binary
*.pptx      binary
*.doc       binary
*.xls       binary
*.ppt       binary

# --- Archives ---
*.zip       binary
*.gz        binary
*.tgz       binary
*.tar       binary
*.7z        binary
*.rar       binary

# --- ML model artifacts (binary, gitignored anyway) ---
*.onnx      binary
*.pt        binary
*.pth       binary
*.safetensors binary
*.bin       binary
*.h5        binary
*.tflite    binary
*.gguf      binary
*.ggml      binary

# --- Minified bundles ---
*.min.js    binary
*.min.css   binary
*.map       text eol=lf

# --- Fonts ---
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary

# --- GitHub linguist hints ---
packages/i18n/locales/*.json linguist-detectable=false
apps/api/migrations/versions/*.py linguist-generated=false
