PORT=8001
ENVIRONMENT=development
LOG_LEVEL=INFO

# Vision model bundle. Point at a LOCAL DIRECTORY containing the
# files written by services/training/src/export.py:
#     plantvit.onnx (or plantvit-int8.onnx)
#     labels.json
#     provenance.json
# Production deploys: aws s3 sync s3://bal-models/plantvit-v0/ /mnt/models/plantvit-v0
VISION_MODEL_URI=/mnt/models/plantvit-v0
VISION_MODEL_VERSION=plantvit-v0-stub
LLM_MODEL_NAME=gemma-2-9b-it
LLM_ADAPTER_URI=

# Toggle: when true, /predict returns deterministic mock results
# (the dev default). When false, RealPredictor loads VISION_MODEL_URI
# and pulls the source image from object storage on each call.
USE_MOCK_PREDICTOR=true

# S3 settings — only used when USE_MOCK_PREDICTOR=false (the real
# predictor downloads original images on demand). Must match the API's
# bucket / endpoint / creds, since we read from the same uploads/ prefix.
S3_BUCKET=bharat-agri-lens-dev
S3_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
